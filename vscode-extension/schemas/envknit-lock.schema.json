{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EnvKnit Lock File",
  "description": "Schema for envknit.lock.yaml — auto-generated, do not edit manually",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Lock file schema version"
    },
    "lock_generated_at": {
      "type": "string",
      "description": "ISO 8601 timestamp of when the lock file was generated"
    },
    "resolver_version": {
      "type": "string",
      "description": "Version of the resolver that generated this lock file"
    },
    "packages": {
      "type": "array",
      "description": "Resolved package list with pinned versions",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "version": { "type": "string" },
          "extras": {
            "type": "array",
            "items": { "type": "string" }
          },
          "hash": { "type": "string" },
          "url": { "type": "string" }
        },
        "required": ["name", "version"]
      }
    },
    "environments": {
      "type": "object",
      "description": "Per-environment resolved package sets",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "packages": {
            "type": "array",
            "items": { "type": "string" }
          },
          "python_version": { "type": "string" },
          "backend": { "type": "string" }
        }
      }
    },
    "dependency_graph": {
      "type": "object",
      "description": "Resolved dependency graph edges (package -> list of dependencies)",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    }
  },
  "additionalProperties": false
}
